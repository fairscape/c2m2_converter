{
  "_doc": "C2M2 phenotype CV term table -> one schema.org DefinedTerm per row. See mappings/cv/disease.json for the shared shape. 'usedBy' back-references the subjects that cite this phenotype.",
  "source_table": "phenotype",
  "entity_type": "DefinedTerm",
  "order": 38,

  "cv_source": {"column": "id", "source_table": "phenotype"},

  "id": {"strategy": "ontology_term", "column": "id", "source_table": "phenotype"},

  "constants": {
    "isPartOf": [{"@id": "{prefix}-table-phenotype"}, {"@id": "{crate_guid}"}]
  },

  "fields": [
    {"source": "name", "target": "name", "parser": "name_or_curie"},
    {"source": "id", "target": "termCode", "parser": "scalar"},
    {"source": "id", "target": "identifier", "parser": "ontology_term", "source_table": "phenotype"},
    {"source": "description", "target": "description", "parser": "description_or_template", "template": "C2M2 phenotype controlled-vocabulary term {curie}{onto_suffix}, referenced by the {dcc_label} instance."},
    {"source": "synonyms", "target": "synonym", "parser": "json_string_list"}
  ],

  "additional_property": [
    {"name": "c2m2CvTable", "parser": "property_value_const", "const": "phenotype"}
  ],

  "associations": [
    {
      "assoc_table": "subject_phenotype",
      "match": {"columns": ["phenotype"], "resolver": "ontology_term", "source_table": "phenotype"},
      "value": {"columns": ["subject_id_namespace", "subject_local_id"], "resolver": "entity_guid", "entity": "subject"},
      "targets": ["usedBy"],
      "wrap": "ident_ref"
    }
  ]
}
