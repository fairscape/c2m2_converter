{
  "_doc": "C2M2 data_type CV term table -> one schema.org DefinedTerm per row. See mappings/cv/disease.json for the shared shape. 'usedBy' back-references files whose data_type column resolves to this EDAM term.",
  "source_table": "data_type",
  "entity_type": "DefinedTerm",
  "order": 35,

  "cv_source": {"column": "id", "source_table": "data_type"},

  "id": {"strategy": "ontology_term", "column": "id", "source_table": "data_type"},

  "constants": {
    "isPartOf": [{"@id": "{prefix}-table-data_type"}, {"@id": "{crate_guid}"}]
  },

  "fields": [
    {"source": "name", "target": "name", "parser": "name_or_curie"},
    {"source": "id", "target": "termCode", "parser": "scalar"},
    {"source": "id", "target": "identifier", "parser": "ontology_term", "source_table": "data_type"},
    {"source": "description", "target": "description", "parser": "description_or_template", "template": "C2M2 data type controlled-vocabulary term {curie}{onto_suffix}, referenced by the {dcc_label} instance."},
    {"source": "synonyms", "target": "synonym", "parser": "json_string_list"}
  ],

  "additional_property": [
    {"name": "c2m2CvTable", "parser": "property_value_const", "const": "data_type"}
  ],

  "associations": [
    {
      "assoc_table": "file",
      "match": {"columns": ["data_type"], "resolver": "ontology_term", "source_table": "data_type"},
      "value": {"columns": ["id_namespace", "local_id"], "resolver": "entity_guid", "entity": "file"},
      "targets": ["usedBy"],
      "wrap": "ident_ref"
    }
  ]
}
