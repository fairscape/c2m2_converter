{
  "_doc": "C2M2 substance CV term table -> one schema.org DefinedTerm per row. See mappings/cv/disease.json for the shared shape. The 'id' column is a bare PubChem Substance accession (resolved via the substance source_table). The 'compound' column (the PubChem Compound this substance maps to) is preserved in additionalProperty; 'usedBy' back-references biosamples and subjects that cite this substance.",
  "source_table": "substance",
  "entity_type": "DefinedTerm",
  "order": 42,

  "cv_source": {"column": "id", "source_table": "substance"},

  "id": {"strategy": "ontology_term", "column": "id", "source_table": "substance"},

  "constants": {
    "isPartOf": [{"@id": "{prefix}-table-substance"}, {"@id": "{crate_guid}"}]
  },

  "fields": [
    {"source": "name", "target": "name", "parser": "name_or_curie"},
    {"source": "id", "target": "termCode", "parser": "scalar"},
    {"source": "id", "target": "identifier", "parser": "ontology_term", "source_table": "substance"},
    {"source": "description", "target": "description", "parser": "description_or_template", "template": "C2M2 substance controlled-vocabulary term {curie}{onto_suffix}, referenced by the {dcc_label} instance."},
    {"source": "synonyms", "target": "synonym", "parser": "json_string_list"}
  ],

  "additional_property": [
    {"name": "compound", "source": "compound", "parser": "property_value"},
    {"name": "c2m2CvTable", "parser": "property_value_const", "const": "substance"}
  ],

  "associations": [
    {
      "assoc_table": "biosample_substance",
      "match": {"columns": ["substance"], "resolver": "ontology_term", "source_table": "substance"},
      "value": {"columns": ["biosample_id_namespace", "biosample_local_id"], "resolver": "entity_guid", "entity": "biosample"},
      "targets": ["usedBy"],
      "wrap": "ident_ref"
    },
    {
      "assoc_table": "subject_substance",
      "match": {"columns": ["substance"], "resolver": "ontology_term", "source_table": "substance"},
      "value": {"columns": ["subject_id_namespace", "subject_local_id"], "resolver": "entity_guid", "entity": "subject"},
      "targets": ["usedBy"],
      "wrap": "ident_ref"
    }
  ]
}
