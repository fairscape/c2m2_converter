{
  "_doc": "C2M2 sample_prep_method CV term table -> one schema.org DefinedTerm per row. See mappings/cv/disease.json for the shared shape. 'usedBy' back-references biosamples whose sample_prep_method column resolves to this OBI term.",
  "source_table": "sample_prep_method",
  "entity_type": "DefinedTerm",
  "order": 32,

  "cv_source": {"column": "id", "source_table": "sample_prep_method"},

  "id": {"strategy": "ontology_term", "column": "id", "source_table": "sample_prep_method"},

  "constants": {
    "isPartOf": [{"@id": "{prefix}-table-sample_prep_method"}, {"@id": "{crate_guid}"}]
  },

  "fields": [
    {"source": "name", "target": "name", "parser": "name_or_curie"},
    {"source": "id", "target": "termCode", "parser": "scalar"},
    {"source": "id", "target": "identifier", "parser": "ontology_term", "source_table": "sample_prep_method"},
    {"source": "description", "target": "description", "parser": "description_or_template", "template": "C2M2 sample preparation method controlled-vocabulary term {curie}{onto_suffix}, referenced by the {dcc_label} instance."},
    {"source": "synonyms", "target": "synonym", "parser": "json_string_list"}
  ],

  "additional_property": [
    {"name": "c2m2CvTable", "parser": "property_value_const", "const": "sample_prep_method"}
  ],

  "associations": [
    {
      "assoc_table": "biosample",
      "match": {"columns": ["sample_prep_method"], "resolver": "ontology_term", "source_table": "sample_prep_method"},
      "value": {"columns": ["id_namespace", "local_id"], "resolver": "entity_guid", "entity": "biosample"},
      "targets": ["usedBy"],
      "wrap": "ident_ref"
    }
  ]
}
